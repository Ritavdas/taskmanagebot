{
  "name": "whatnottodo-bot",
  "version": "0.2.0",
  "description": "Personal task OS — Discord bot + Linear + AI parsing. Morning digest at 10:30 AM, evening close-out at 10:30 PM.",
  "type": "module",
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "bootstrap": "tsx src/bootstrap.ts",
    "digest:test": "tsx src/index.ts --run-digest",
    "closeout:test": "tsx src/index.ts --run-closeout",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "@linear/sdk": "^84.0.0",
    "ai": "^6.0.184",
    "croner": "^10.0.1",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.2",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^22.10.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
