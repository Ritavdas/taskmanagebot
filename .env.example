# Discord
DISCORD_BOT_TOKEN=
DISCORD_OWNER_ID=          # Your Discord user ID — bot only talks to this user

# Linear
LINEAR_API_KEY=            # https://linear.app/settings/api
LINEAR_TEAM_KEY=PER        # Linear team key (e.g., PER for "Personal")

# AI (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Schedule
TIMEZONE=Asia/Kolkata
MORNING_CRON=30 10 * * *   # 10:30 AM
EVENING_CRON=30 22 * * *   # 10:30 PM

# Optional: skip cron and only respond to messages (for dev)
DISABLE_CRON=false
